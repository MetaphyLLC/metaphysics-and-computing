# ── Oracle Bridge Server — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's in .gitignore.

# DeepInfra API key (get from https://deepinfra.com/dashboard)
DEEPINFRA_API_KEY=your_key_here

# UAIMC knowledge base URL (Logan's existing service)
# Local development: http://localhost:8765
# Railway (internal networking): http://uaimc-lite.railway.internal:<PORT>
UAIMC_URL=http://localhost:8765

# Server port
PORT=3001

# Allowed CORS origin (the website frontend)
CORS_ORIGIN=https://www.metaphysicsandcomputing.com

# Rate limiting: max requests per window per IP
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# LLM model (DeepInfra-hosted, thinking suppressed via chat_template_kwargs)
# Options: Qwen/Qwen3.5-397B-A17B (recommended), Qwen/Qwen3.5-72B (lighter)
LLM_MODEL=Qwen/Qwen3.5-397B-A17B

# TTS — Kokoro-FastAPI (OpenAI-compatible, self-hosted on Railway)
# Deploy template: https://railway.com/new/template/kokoro-tts-api
# Leave TTS_BASE_URL blank to disable audio (text-only mode)
TTS_BASE_URL=https://<your-kokoro-service>.up.railway.app/v1
TTS_MODEL=kokoro
TTS_VOICE=af_bella
TTS_API_KEY=not-needed
