# ── Oracle Bridge Server — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's in .gitignore.

# DeepInfra API key (get from https://deepinfra.com/dashboard)
DEEPINFRA_API_KEY=your_key_here

# UAIMC knowledge base URL (Logan's existing service)
UAIMC_URL=http://localhost:8765

# Server port
PORT=3001

# Allowed CORS origin (the website frontend)
CORS_ORIGIN=https://www.metaphysicsandcomputing.com

# Rate limiting: max requests per window per IP
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# LLM model (DeepInfra-hosted)
# Options: Qwen/Qwen3.5-397B-A17B (recommended), Qwen/Qwen3.5-72B (lighter)
LLM_MODEL=Qwen/Qwen3.5-397B-A17B

# TTS voice (DeepInfra-hosted via openai/tts-1)
TTS_VOICE=aura-asteria-en
